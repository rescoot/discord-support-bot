# Discord application bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=

# Comma-separated Discord user IDs allowed to run owner-only commands (e.g. /reload)
OWNER_IDS=

# Optional: restrict slash-command registration to a single guild during development.
# Global commands take up to an hour to propagate; guild commands are instant.
# Leave empty for production (global).
DEV_GUILD_ID=

# Optional: channel ID to post the welcome message in when a DM fails (empty = silent fallback)
WELCOME_FALLBACK_CHANNEL_ID=

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
